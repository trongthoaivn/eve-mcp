# ============================================================
# EVE-MCP Server — .gitignore
# ============================================================

# --- EVE-NG session cookies ---
.eve_session.json

# --- Environment / secrets ---
.env
.env.*
!.env.example

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.pyc
.Python

# --- Virtual environments ---
.venv/
venv/
env/
ENV/
.virtualenv/

# --- Build artifacts ---
build/
dist/
*.egg-info/
*.egg

# --- pip ---
pip-log.txt
pip-delete-this-directory.txt

# --- Packaging ---
MANIFEST
*.whl
*.tar.gz

# --- Testing ---
.pytest_cache/
.tox/
.nox/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
*.hypothesis/

# --- Type checking ---
.mypy_cache/
.dmypy.json
dmypy.json
.pyright/

# --- IDE / editors ---
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Logs ---
*.log
logs/

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb

# --- Distribution / packaging ---
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/

# --- Installer cache ---
*.msix
*.msi
*.exe
!startup.ps1
