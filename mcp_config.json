{
  "mcpServers": {
    "eve-mcp": {
      "command": "d:/GIT/eve-mcp/.venv/Scripts/python.exe",
      "args": [
        "-u",
        "d:/GIT/eve-mcp/server.py"
      ],
      "env": {
        "EVE_HOST": "192.168.112.128",
